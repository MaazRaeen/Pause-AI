# Pause AI - Backend Environment Variables Template
# Copy to .env and fill in your actual values

# ---- Core Application Settings ----
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
LOG_LEVEL=INFO
ENVIRONMENT=development

# ---- OpenAI & Whisper Configuration ----
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
WHISPER_MODEL=base

# ---- Vector Database Configuration ----
VECTOR_DB_TYPE=faiss

# FAISS (local development)
FAISS_INDEX_PATH=./data/faiss_index

# Pinecone (cloud - uncomment when using)
# PINECONE_API_KEY=your-pinecone-api-key
# PINECONE_ENVIRONMENT=gcp-starter
# PINECONE_INDEX_NAME=pauseai

# ---- File Storage ----
TEMP_STORAGE_PATH=./temp
PROCESSING_DATA_PATH=./data
MAX_VIDEO_SIZE_MB=500

# ---- CORS Configuration ----
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ---- Database (optional) ----
# DATABASE_URL=postgresql://user:password@localhost:5432/pauseai

# ---- Redis (optional) ----
# REDIS_URL=redis://localhost:6379
